# Supabase (dedicated project for autonomous-trader -- separate from investment-monitor)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Alpaca paper trading keys.
# These are a DIFFERENT, more sensitive permission grant than investment-monitor's
# market-data-only keys -- these can place orders. Reusing the same Alpaca
# ACCOUNT is fine; generate keys with the trading toolset enabled for this app.
ALPACA_API_KEY=
ALPACA_SECRET_KEY=

# "paper" is the only supported value until live trading is built as its own
# explicit second phase. Do not set this to "live" -- there is no live-trading
# code path yet, and setting it will cause startup to fail closed.
TRADING_MODE=paper

# Optional: for the LLM-based signals (news sentiment) and agents (portfolio
# manager). Not required for Phase 0 (safety rails / risk scorer have no LLM
# dependency).
ANTHROPIC_API_KEY=

# SEC EDGAR requires a descriptive User-Agent on every request (no API key).
# Format recommended by SEC: "<app name> <contact email>". Requests without
# one (or with a generic/browser-spoofed one) get blocked.
SEC_EDGAR_USER_AGENT="autonomous-trader lazar.ryan123@gmail.com"
